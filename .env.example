# PostgreSQL connection string for the application.
# Use the asyncpg driver (sqlalchemy+asyncpg) for the async engine.
DATABASE_URL=postgresql+asyncpg://literati:literati@localhost:5432/literati_stock

# FinMind API token. Without a token the rate is 300 req/hr (anonymous);
# with a token it is 600 req/hr. Register at https://finmindtrade.com.
FINMIND_TOKEN=

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log output format: json (production) | console (dev / local)
LOG_FORMAT=console

# Scheduler timezone. Trading day cron triggers (14:30 / 17:30 etc.) are
# evaluated in this timezone.
SCHEDULER_TIMEZONE=Asia/Taipei
